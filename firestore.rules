rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable core helpers
    function isSignedIn() {
      // Return true to allow easy dev and prototype syncing without requiring Firebase Auth setups
      return true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Tournaments match block
    match /tournaments/{tournamentId} {
      allow read, write: if true;

      // Teams nested sub-resources
      match /teams/{teamId} {
        allow read, write: if true;

        // Players nested sub-resources
        match /players/{playerId} {
          allow read, write: if true;
        }
      }

      // Matches nested sub-resources
      match /matches/{matchId} {
        allow read, write: if true;
      }
    }

    // Support collectionGroup queries for teams across any path
    match /{path=**}/teams/{teamId} {
      allow read, write: if true;
    }

    // Support collectionGroup queries for matches across any path
    match /{path=**}/matches/{matchId} {
      allow read, write: if true;
    }

    // Sponsors match block
    match /sponsors/{sponsorId} {
      allow read, write: if true;
    }

    // Athletes match block
    match /athletes/{athleteId} {
      allow read, write: if true;
    }

    // System state config match block
    match /system_state/{configId} {
      allow read, write: if true;
    }

    // Posts news match block
    match /posts/{postId} {
      allow read, write: if true;
    }

    // Banner Slides match block
    match /slides/{slideId} {
      allow read, write: if true;
    }
  }
}
